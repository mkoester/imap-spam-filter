# IMAP server connection
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=user@example.com
# Shell command that prints the IMAP password to stdout.
# Examples:
#   "cat /path/to/passfile"
#   "pass show email/imap"
#   "secret-tool lookup host imap.example.com"
IMAP_PASS_CMD="cat /path/to/mailpass"

# IMAP folder names (as they appear on the server)
INBOX_FOLDER=INBOX
JUNK_FOLDER=Junk

# Local account identifier — used as the maildir subdirectory name.
# Keep it short and filesystem-friendly (no spaces).
ACCOUNT_NAME=myaccount

# Base directory for local mail storage, state files, and bogofilter database.
# Will be created by setup.sh if it does not exist.
DATA_DIR=$HOME/.local/share/imap-spam-filter
